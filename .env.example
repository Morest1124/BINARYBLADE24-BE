# ====================================================================
# DJANGO CONFIGURATION
# ====================================================================
SECRET_KEY=django-insecure-your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1

# ====================================================================
# DATABASE CONFIGURATION
# ====================================================================
# MySQL Database
MYSQL_DATABASE=your_database_name
MYSQL_HOST=localhost
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_PORT=3306

# PostgreSQL (if using)
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# ====================================================================
# ESCROW API CONFIGURATION
# ====================================================================
# Escrow.com API credentials (NEVER commit real credentials to git!)
# Get your credentials from: https://www.escrow.com/developer
# For sandbox testing: https://sandbox.escrow.com

ESCROW_API_URL=https://api.escrow-sandbox.com/2017-09-01
ESCROW_API_EMAIL=your-escrow-account@example.com
ESCROW_API_KEY=your_api_key_here_replace_with_real_key
ESCROW_WEBHOOK_SECRET=your_webhook_secret_here

# Platform Fee Configuration (Three-Way Payment Split)
# Platform commission: 20%, Freelancer payout: 80%
PLATFORM_FEE_PERCENTAGE=0.20
FREELANCER_PAYOUT_PERCENTAGE=0.80

# ====================================================================
# EMAIL CONFIGURATION
# ====================================================================
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password

# ====================================================================
# OPTIONAL: CORS & SECURITY
# ====================================================================
DEBUG=False
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com,https://localhost:3000
